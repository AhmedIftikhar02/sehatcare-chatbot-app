<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable container: put your real content as a direct child, then wrap it with this.
    Used from any Fragment's layout like:

    <com.example.my_boilerplate.common.widgets.StateLayout
        android:id="@+id/stateLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView ... />

    </com.example.my_boilerplate.common.widgets.StateLayout>

    Then in code: stateLayout.showLoading() / showContent() / showError(message) { retryAction() } / showEmpty()
    See common/widgets/StateLayout.kt for the implementation.
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/errorContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/dp_24"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.App.Body"
            android:textAlignment="center"
            android:text="@string/error_generic" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            style="@style/Widget.App.Button.Outline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_16"
            android:text="@string/action_retry" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/emptyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/dp_24"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.App.Body"
            android:textAlignment="center"
            android:text="@string/empty_generic" />

    </LinearLayout>

</merge>
