<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_surface" />
            <stroke android:width="@dimen/stroke_width_medium" android:color="@color/color_primary" />
            <corners android:radius="@dimen/corner_radius_small" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/color_surface" />
            <stroke android:width="@dimen/stroke_width_thin" android:color="@color/color_outline" />
            <corners android:radius="@dimen/corner_radius_small" />
        </shape>
    </item>
</selector>
