    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/color_on_surface_variant</item>
    </style>
    <style name="TextAppearance.App.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/color_hint</item>
    </style>
    <style name="TextAppearance.App.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/color_on_background</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.App.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/color_on_background</item>
    </style>
    <style name="Theme.MyBoilerplate" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorOnSecondary">@color/color_on_secondary</item>

        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorOnBackground">@color/color_on_background</item>

        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorSurfaceVariant">@color/color_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/color_on_surface_variant</item>

        <item name="colorOutline">@color/color_outline</item>
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/color_on_error</item>

        
        <item name="android:statusBarColor">@color/color_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/color_background</item>

        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:fitsSystemWindows" ns1:targetApi="21">false</item>
    </style>
    <style name="Theme.MyBoilerplate.Splash" parent="Theme.MyBoilerplate">
        <item name="android:windowBackground">@color/color_background</item>
    </style>
    <style name="Widget.App.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:background">@drawable/bg_button_outline</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="strokeWidth">0dp</item>
    </style>
    <style name="Widget.App.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/corner_radius_full</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>
    <style name="Widget.App.Button.Primary.Gradient" parent="Widget.App.Button.Primary">
        <item name="android:background">@drawable/bg_button_primary_gradient</item>
        <item name="backgroundTint">@null</item>
    </style>
    <style name="Widget.App.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/corner_radius_full</item>
    </style>
    <style name="Widget.App.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/color_card_bg</item>
        <item name="cardCornerRadius">@dimen/corner_radius_medium</item>
        <item name="cardElevation">@dimen/elevation_small</item>
        <item name="contentPadding">@dimen/dp_16</item>
    </style>
    <style name="Widget.App.EditText.Filled" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_edittext_filled</item>
        <item name="android:padding">@dimen/dp_16</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:textColor">@color/color_on_surface</item>
        <item name="android:textColorHint">@color/color_hint</item>
        <item name="android:minHeight">@dimen/edittext_height</item>
    </style>
    <style name="Widget.App.EditText.Outline" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_edittext_outline</item>
        <item name="android:padding">@dimen/dp_16</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:textColor">@color/color_on_surface</item>
        <item name="android:textColorHint">@color/color_hint</item>
        <item name="android:minHeight">@dimen/edittext_height</item>
    </style>
</resources>